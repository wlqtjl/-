# 我在 (WoZai) - 环境变量配置模板
# 复制为 .env 后修改

# ===== 服务配置 =====
LISTEN_ADDR=:8080

# ===== 数据库 =====
# Docker 部署时由 compose 自动组装，裸机部署需手动填写
POSTGRES_PASSWORD=changeme_use_random_string
DATABASE_URL=postgres://wozai:${POSTGRES_PASSWORD}@db:5432/wozai?sslmode=disable

# ===== 安全 =====
JWT_SECRET=changeme_must_be_at_least_32_characters_long_random

# ===== AI 对话 (必填) =====
DEEPSEEK_API_KEY=sk-请填入你的DeepSeek_API_Key
DEEPSEEK_URL=https://api.deepseek.com/v1/chat/completions

# ===== 语音合成 (必填) =====
SILICONFLOW_API_KEY=sk-请填入你的SiliconFlow_API_Key
SILICONFLOW_URL=https://api.siliconflow.cn/v1/audio/speech

# ===== 令牌有效期 =====
ACCESS_TOKEN_TTL=15
REFRESH_TOKEN_TTL=168

# ===== 多模型 (可选) =====
AI_PROVIDER=deepseek
# OPENAI_API_KEY=
# OPENAI_URL=https://api.openai.com/v1/chat/completions
# GEMMA_API_KEY=请填入你的Google_AI_Studio_API_Key(免费)
# GEMMA_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions

# ===== 情感分析 (可选) =====
ENABLE_SENTIMENT=false
